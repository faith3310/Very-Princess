{
  "version": 2,
  "name": "very-princess-frontend",
  "builds": [
    {
      "src": "packages/frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "packages/frontend/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_BACKEND_URL": "@backend-url"
  },
  "buildCommand": "cd packages/frontend && npm run build",
  "outputDirectory": "packages/frontend/.next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "packages/frontend/pages/api/**/*.js": {
      "maxDuration": 30
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": false,
      "develop": true,
      "staging": true
    }
  }
}
